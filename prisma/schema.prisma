// ===== PHASE 4: Tracking Event Sourcing Enums =====

// Phân biệt loại sự kiện — không phải mọi event đều thay đổi status
enum TrackingEventType {
  STATUS_CHANGE // Chuyển trạng thái đơn hàng (PENDING → ASSIGNED...)
  SCAN // Quét barcode/QR tại kho (không đổi status)
  NOTE // Ghi chú thuần thông tin
  POD // Upload bằng chứng giao hàng
  EXCEPTION // Sự cố: giao thất bại, hư hỏng, mất hàng
  ETA_UPDATE // Cập nhật thời gian dự kiến giao
}

// Nguồn gốc event — biết event đến từ đâu để audit và debug
enum EventSource {
  DRIVER_APP // Từ ứng dụng tài xế trên điện thoại
  HUB_SCANNER // Từ máy quét barcode tại kho bãi
  SYSTEM // Hệ thống tự động (Bin Packing, Auto-dispatch)
  ADMIN_PORTAL // Admin can thiệp thủ công từ dashboard
  CUSTOMER_APP // Khách hàng thao tác (hủy đơn, yêu cầu đổi địa chỉ)
}

// Lý do giao hàng thất bại — chuẩn hóa theo industry standard
// 15-25% đơn hàng ở VN giao thất bại lần đầu
enum FailureReasonCode {
  CUSTOMER_NOT_AVAILABLE // Khách không có mặt
  INCORRECT_ADDRESS // Sai địa chỉ
  REFUSED_BY_CUSTOMER // Khách từ chối nhận hàng
  BUSINESS_CLOSED // Cơ sở kinh doanh đóng cửa
  INACCESSIBLE_LOCATION // Không thể tiếp cận (ngõ hẹp, tầng cao...)
  PACKAGE_DAMAGED // Kiện hàng hư hỏng
  WEATHER_DELAY // Thời tiết xấu
  VEHICLE_BREAKDOWN // Xe hỏng
  OTHER // Lý do khác
}

// Tình trạng kiện hàng khi giao cho Proof of Delivery
enum PackageCondition {
  INTACT // Nguyên vẹn
  DAMAGED // Hư hỏng
  PARTIAL // Giao thiếu (một phần)
}

// Loại ảnh trong Proof of Delivery — phân loại để hiển thị đúng UI
enum ProofImageType {
  PACKAGE // Ảnh kiện hàng
  SIGNATURE // Ảnh chữ ký khách hàng
  DELIVERY_LOCATION // Ảnh vị trí giao (trước cổng, bàn bảo vệ...)
  DAMAGE_EVIDENCE // Ảnh minh chứng hư hỏng
  FAILED_ATTEMPT // Ảnh minh chứng giao thất bại (cửa đóng, không có người...)
}
