{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "builder": "webpack",
    "strictNullChecks": true,
    "esModuleInterop": true
  },
  "generateOptions": {
    "spec": false
  }
}
