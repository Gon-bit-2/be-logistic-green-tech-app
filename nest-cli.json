{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "builder": "tsc",
    "assets": [
      {
        "include": "../generated/**/*",
        "outDir": "dist/generated"
      }
    ],
    "watchAssets": true,
    "strictNullChecks": true,
    "esModuleInterop": true
  },
  "generateOptions": {
    "spec": false
  }
}
