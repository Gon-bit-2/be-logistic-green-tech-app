{
  "moduleFileExtensions": ["js", "json", "ts", "tsx"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/../src/$1",
    "^generated/(.*)$": "<rootDir>/../generated/$1",
    "^emails/(.*)$": "<rootDir>/../emails/$1",
    "^uuid$": "<rootDir>/uuid-mock.js"
  },
  "transform": {
    "^.+\\.(t|j)sx?$": "ts-jest"
  }
}
